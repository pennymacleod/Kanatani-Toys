# ── Square API Credentials ───────────────────────────────────────────────────
# Get these from: https://developer.squareup.com
# 1. Sign in → My Applications → New Application → name it "Kanatani Website"
# 2. Click the app → Credentials tab → copy Production Access Token
# 3. Square Dashboard → Account & Settings → Locations → copy Location ID

SQUARE_ACCESS_TOKEN=EAAAl_YOUR_TOKEN_HERE
SQUARE_LOCATION_ID=L_YOUR_LOCATION_ID_HERE

# Square environment: "production" or "sandbox"
SQUARE_ENVIRONMENT=production
